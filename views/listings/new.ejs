<% layout("/layout/boilerplate"); %>

    <body>
        <div class="editBody">

            <form action="/listings" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">
                <h1>Create New Listing : </h1>
                <div class="editImg">
                    <label for="description">Title : </label>
                    <input type="text" name="listing[title]" placeholder="Enter Title of the listing" required>
                    <div class="invalid-feedback">Please add a valid title.</div>
                </div>

                <div class="editDesc">
                    <label for="description">Description : </label>
                    <textarea name="listing[description]" placeholder="Enter description" required></textarea>
                    <div class="invalid-feedback">Please add a valid description.</div>
                </div>

                <div class="editImg">
                    <label for="image">Upload Image : </label>
                    <input type="file" name="listing[image]" class="imageBox">
                </div>

                <div class="category">
                    <label for="categories">Category :</label>
                    <select name="listing[category]" id="categories">
                        <option value="Icons">Icons</option>
                        <option value="Design" selected>Design</option>
                        <option value="Amazing pools">Amazing pools</option>
                        <option value="Beachfront">Beachfront</option>
                        <option value="Cabins">Cabins</option>
                        <option value="Mansions">Mansions</option>
                        <option value="Trending">Trending</option>
                        <option value="Lakefront">Lakefront</option>
                        <option value="Countryside">Countryside</option>
                        <option value="National parks">National parks</option>
                        <option value="Caves">Caves</option>
                        <option value="Tropical">Tropical</option>
                        <option value="Historical homes">Historical homes</option>
                        <option value="Camping">Camping</option>
                        <option value="Tiny homes">Tiny homes</option>
                        <option value="Amazing views">Amazing views</option>
                        <option value="Islands">Islands</option>
                        <option value="Castles">Castles</option>
                        <option value="Farmhouses">Farmhouses</option>
                        <option value="Surfing">Surfing</option>
                        <option value="Beach">Beach</option>
                        <option value="Skiing">Skiing</option>
                        <option value="Bed & breakfasts">Bed & breakfasts</option>
                        <option value="Golfing">Golfing</option>
                        <option value="Creative spaces">Creative spaces</option>
                        <option value="Chef's kitchens">Chef's kitchens</option>
                        <option value="Luxe">Luxe</option>
                        <option value="Vineyard">Vineyard</option>
                        <option value="New">New</option>
                        <option value="Top of the world">Top of the world</option>
                        <option value="Off-the-grid">Off-the-grid</option>
                        <option value="Treehouses">Treehouses</option>
                        <option value="Play">Play</option>
                        <option value="Lake">Lake</option>
                        <option value="Hanoks">Hanoks</option>
                        <option value="Ryokans">Ryokans</option>
                        <option value="Minsus">Minsus</option>
                        <option value="Shepherd's huts">Shepherd's huts</option>
                        <option value="Earth homes">Earth homes</option>
                        <option value="Domes">Domes</option>
                        <option value="Yurts">Yurts</option>
                        <option value="Trulli">Trulli</option>
                        <option value="Cycladic homes">Cycladic homes</option>
                        <option value="Campervans">Campervans</option>
                        <option value="Windmills">Windmills</option>
                        <option value="Barns">Barns</option>
                        <option value="Towers">Towers</option>
                        <option value="Houseboats">Houseboats</option>
                        <option value="Boats">Boats</option>
                        <option value="Desert">Desert</option>
                        <option value="Arctic">Arctic</option>
                        <option value="Ski-in/out">Ski-in/out</option>
                        <option value="Grand pianos">Grand pianos</option>
                    </select>
                </div>

                <div class="priceLocation">
                    <div class="editPrice">
                        <label for="price">Price : </label>
                        <input name="listing[price]" placeholder="Enter Price" required>
                        <div class="invalid-feedback">Please add a valid price.</div>
                    </div>

                    <div class="fullLoc">
                        <label for="location">Location :</label>
                        <input type="text" name="listing[location]" placeholder="Enter Location" class="locInput"
                            required>
                        <div class="invalid-feedback locationFeedback">Please add a valid location.</div>
                    </div>
                </div>
                <button class="editBtn newBtn">Create</button>
            </form>
        </div>
    </body>